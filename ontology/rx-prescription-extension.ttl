@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:     <http://purl.org/dc/elements/1.1/> .
@prefix terms:  <http://purl.org/dc/terms/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .

# ── MFSSIA base ontology ──────────────────────────────────────────────────────
@prefix mfssia: <http://www.semanticweb.org/mubashar/ontologies/2024/4/MFSSIA-ontology#> .

# ── UFO annotation properties (reusing MFSSIA's own UFO namespace) ────────────
@prefix ufo:    <http://www.semanticweb.org/mubashar/ontologies/2024/4/MFSSIA-ontology#ufo:> .

# ── This extension ────────────────────────────────────────────────────────────
@prefix rx:     <https://mfssia.io/ontology/prescription#> .

# ── External terminologies ────────────────────────────────────────────────────
@prefix snomed: <http://snomed.info/id/> .
@prefix loinc:  <http://loinc.org/rdf#> .
@prefix fhir:   <http://hl7.org/fhir/> .

# ═══════════════════════════════════════════════════════════════════════════════
# ONTOLOGY DECLARATION
# ═══════════════════════════════════════════════════════════════════════════════

<https://mfssia.io/ontology/prescription>
    a owl:Ontology ;
    owl:imports <http://www.semanticweb.org/mubashar/ontologies/2024/4/MFSSIA-ontology> ;
    owl:versionInfo "1.0"^^xsd:decimal ;
    dc:creator "Aleksandr Kormiltsyn (aleksandr.kormiltson@taltech.ee)" ;
    dc:title "Prescription Extension of MFSSIA Ontology" ;
    rdfs:comment """
        Extension of the MFSSIA ontology for decentralized e-health prescription workflows.
        Implements the running case from: 'Resolving Semantic Conflicts in Decentralized
        E-Health Governance Using Zero-Knowledge Proofs' (Kormiltsyn, Udokwu, Norta, 2025).

        Covers:
          - Healthcare stakeholder roles (Physician, Patient, Laboratory, Pharmacy)
          - Clinical entities: Medication, MedicationClass, Allergy, LabResult
          - Semantic predicates: Al(p,s), Ct(p,m), Au(d,a), PolOk(p,m), Rx(d,p,m)
          - Evaluation context: Γ = ⟨src, ts, cred⟩
          - SNOMED CT / local terminology alignment bridges
          - Clinical policy axioms: Pol(m, t, op, θ)
          - ZKP binding: stmtHash, policyVersion, outcome
    """ ;
    terms:license <https://creativecommons.org/licenses/by/4.0> .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 1 — OBJECT PROPERTIES
# ═══════════════════════════════════════════════════════════════════════════════

# ── Prescription relations ────────────────────────────────────────────────────

rx:prescribedBy
    a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  rx:Physician ;
    rdfs:comment "Links a Prescription to the Physician who issued it. DL: prescribedBy exactly 1 Physician." ;
    rdfs:label "prescribedBy" .

rx:prescribes
    a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  rx:Medication ;
    rdfs:comment "Links a Prescription to the Medication being prescribed. DL: prescribes exactly 1 Medication." ;
    rdfs:label "prescribes" .

rx:prescribedFor
    a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  rx:Patient ;
    rdfs:comment "Links a Prescription to the Patient for whom it is issued. DL: prescribedFor exactly 1 Patient." ;
    rdfs:label "prescribedFor" .

rx:governedBy
    a owl:ObjectProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  rx:ClinicalPolicy ;
    rdfs:comment "Associates a Prescription with the ClinicalPolicy axioms that govern its validity." ;
    rdfs:label "governedBy" .

rx:evaluatedUnder
    a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  rx:EvaluationContext ;
    rdfs:comment "Links a Prescription to the EvaluationContext (Γ) used during semantic validation." ;
    rdfs:label "evaluatedUnder" .

# ── Allergy / Contraindication relations ─────────────────────────────────────

rx:hasAllergy
    a owl:ObjectProperty ;
    rdfs:domain rx:Patient ;
    rdfs:range  rx:Allergy ;
    rdfs:comment "Links a Patient to their documented Allergy records. Corresponds to Al(p,s) in Definition 2." ;
    rdfs:label "hasAllergy" .

rx:allergicToSubstance
    a owl:ObjectProperty ;
    rdfs:domain rx:Allergy ;
    rdfs:range  rx:MedicationClass ;
    rdfs:comment "Links an Allergy record to the substance or medication class. Populates I(Al)." ;
    rdfs:label "allergicToSubstance" .

rx:hasContraindication
    a owl:ObjectProperty ;
    rdfs:domain rx:Patient ;
    rdfs:range  rx:Medication ;
    rdfs:comment """
        Derived contraindication: Ct(p,m). Inferred via inference rule:
        Al(p,s) ∧ (m ⊑ s) → Ct(p,m).
        Populated by the Hypothesis Checker from I(Al) and subsumption closure of T.
    """ ;
    rdfs:label "hasContraindication" .

# ── Medication class hierarchy ────────────────────────────────────────────────

rx:belongsToClass
    a owl:ObjectProperty ;
    rdfs:domain rx:Medication ;
    rdfs:range  rx:MedicationClass ;
    rdfs:comment "Assigns a Medication to its pharmacological class. Supports subsumption m ⊑ s." ;
    rdfs:label "belongsToClass" .

rx:subsumes
    a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain rx:MedicationClass ;
    rdfs:range  rx:MedicationClass ;
    rdfs:comment "Ontological hierarchy: s1 ⊑ s2 (s1 is a subclass of s2). E.g., Penicillin ⊑ β-lactam." ;
    rdfs:label "subsumes" .

# ── Lab results ───────────────────────────────────────────────────────────────

rx:hasLabResult
    a owl:ObjectProperty ;
    rdfs:domain rx:Patient ;
    rdfs:range  rx:LabResult ;
    rdfs:comment "Links a Patient to their laboratory results. ClinVal(p,t) is derived from these." ;
    rdfs:label "hasLabResult" .

rx:measuredBy
    a owl:ObjectProperty ;
    rdfs:domain rx:LabResult ;
    rdfs:range  rx:TrustedDataSource ;
    rdfs:comment "Links a LabResult to the laboratory that produced it. Populates src in Γ." ;
    rdfs:label "measuredBy" .

# ── Authorization relations ───────────────────────────────────────────────────

rx:isAuthorizedBy
    a owl:ObjectProperty ;
    rdfs:domain rx:PrescribingAuthority ;
    rdfs:range  mfssia:Authentication ;
    rdfs:comment "Links a PrescribingAuthority relator to the MFSSIA Authentication that established it." ;
    rdfs:label "isAuthorizedBy" .

rx:grantsAuthorityTo
    a owl:ObjectProperty ;
    rdfs:domain rx:PrescribingAuthority ;
    rdfs:range  rx:Physician ;
    rdfs:comment "Links a PrescribingAuthority to the Physician who holds the prescribing right. Au(d, prescribe)." ;
    rdfs:label "grantsAuthorityTo" .

rx:holdsAttestation
    a owl:ObjectProperty ;
    rdfs:domain rx:Physician ;
    rdfs:range  mfssia:Authentication ;
    rdfs:comment """
        Links a Physician to their MFSSIA Authentication credential (cred in Γ).
        Auth(cred) is checked against this. Used to verify Au(d, prescribe).
    """ ;
    rdfs:label "holdsAttestation" .

# ── Consent relations ─────────────────────────────────────────────────────────

rx:hasConsent
    a owl:ObjectProperty ;
    rdfs:domain rx:Patient ;
    rdfs:range  rx:DataSharingConsent ;
    rdfs:comment "Links a Patient to their DataSharingConsent (required for cross-organizational data access)." ;
    rdfs:label "hasConsent" .

rx:consentCovers
    a owl:ObjectProperty ;
    rdfs:domain rx:DataSharingConsent ;
    rdfs:range  mfssia:Organization ;
    rdfs:comment "Specifies which Organizations are covered by the Patient's data sharing consent." ;
    rdfs:label "consentCovers" .

# ── Clinical policy relations ─────────────────────────────────────────────────

rx:appliesToMedication
    a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain rx:ClinicalPolicy ;
    rdfs:range  rx:Medication ;
    rdfs:comment "Links a ClinicalPolicy axiom to the Medication it constrains. Pol(m, t, op, θ) → m." ;
    rdfs:label "appliesToMedication" .

# ── Evaluation context relations ──────────────────────────────────────────────

rx:hasDataSource
    a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain rx:EvaluationContext ;
    rdfs:range  rx:TrustedDataSource ;
    rdfs:comment "Links EvaluationContext to its data source. Corresponds to src in Γ = ⟨src, ts, cred⟩." ;
    rdfs:label "hasDataSource" .

rx:usesCredential
    a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain rx:EvaluationContext ;
    rdfs:range  mfssia:Authentication ;
    rdfs:comment "Links EvaluationContext to the MFSSIA credential (cred in Γ). Auth(cred) is verified against this." ;
    rdfs:label "usesCredential" .

# ── Terminology alignment ─────────────────────────────────────────────────────

rx:alignsTo
    a owl:ObjectProperty ;
    rdfs:comment "Bridge property for cross-terminology alignment. E.g., local 'Sensitivity' aligns to SNOMED 'Allergy'." ;
    rdfs:label "alignsTo" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 2 — DATA PROPERTIES
# ═══════════════════════════════════════════════════════════════════════════════

# ── ZKP binding (Table II from the paper) ────────────────────────────────────

rx:stmtHash
    a owl:DatatypeProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  xsd:string ;
    rdfs:comment "Commitment H(φ+ ∥ policyVersion ∥ nonce). Binds the ZKP proof to a specific prescription instance, policy version, and nonce. (Eq. 14)" ;
    rdfs:label "stmtHash" .

rx:proofOutcome
    a owl:DatatypeProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  xsd:boolean ;
    rdfs:comment "Circuit output: true = accept, false = reject. Recorded on-chain by the governance layer." ;
    rdfs:label "proofOutcome" .

rx:policyVersion
    a owl:DatatypeProperty ;
    rdfs:domain rx:ClinicalPolicy ;
    rdfs:range  xsd:string ;
    rdfs:comment "DKG Knowledge Asset UAL identifying the governance-approved snapshot of T. Embedded in stmtHash so policy updates invalidate prior proofs." ;
    rdfs:label "policyVersion" .

rx:nonce
    a owl:DatatypeProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  xsd:string ;
    rdfs:comment "Per-prescription unique value bound into stmtHash to prevent replay attacks." ;
    rdfs:label "nonce" .

# ── Clinical policy axiom properties (Pol(m, t, op, θ)) ──────────────────────

rx:clinicalCondition
    a owl:DatatypeProperty ;
    rdfs:domain rx:ClinicalPolicy ;
    rdfs:range  xsd:string ;
    rdfs:comment "Clinical condition type t in Pol(m, t, op, θ). E.g., 'eGFR', 'age', 'pregnancyStatus'." ;
    rdfs:label "clinicalCondition" .

rx:comparisonOperator
    a owl:DatatypeProperty ;
    rdfs:domain rx:ClinicalPolicy ;
    rdfs:range  xsd:string ;
    rdfs:comment "Comparison operator op ∈ {≥, ≤, =, ≠} in Pol(m, t, op, θ)." ;
    rdfs:label "comparisonOperator" .

rx:threshold
    a owl:DatatypeProperty ;
    rdfs:domain rx:ClinicalPolicy ;
    rdfs:range  xsd:integer ;
    rdfs:comment "Governance-approved numeric threshold θ in Pol(m, t, op, θ). E.g., 30 for eGFR ≥ 30 with Metformin." ;
    rdfs:label "threshold" .

rx:deltaMax
    a owl:DatatypeProperty ;
    rdfs:domain rx:ClinicalPolicy ;
    rdfs:range  xsd:integer ;
    rdfs:comment "Maximum permitted age of clinical evidence in seconds (Δmax). Enforces freshness (tnow − ts) ≤ Δmax." ;
    rdfs:label "deltaMax" .

# ── Lab result data properties ────────────────────────────────────────────────

rx:clinicalValue
    a owl:DatatypeProperty ;
    rdfs:domain rx:LabResult ;
    rdfs:range  xsd:decimal ;
    rdfs:comment "Measured clinical value ClinVal(p, t). E.g., eGFR = 45. Private witness input in ZKP circuit." ;
    rdfs:label "clinicalValue" .

rx:conditionType
    a owl:DatatypeProperty ;
    rdfs:domain rx:LabResult ;
    rdfs:range  xsd:string ;
    rdfs:comment "Type of clinical condition measured. E.g., 'eGFR', 'age'. Maps to t in Pol(m, t, op, θ)." ;
    rdfs:label "conditionType" .

rx:measuredAt
    a owl:DatatypeProperty ;
    rdfs:domain rx:LabResult ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Timestamp ts when the laboratory measurement was recorded. Used in freshness check (tnow − ts) ≤ Δmax." ;
    rdfs:label "measuredAt" .

# ── Allergy data properties ───────────────────────────────────────────────────

rx:snomedCode
    a owl:DatatypeProperty ;
    rdfs:domain rx:Allergy ;
    rdfs:range  xsd:string ;
    rdfs:comment "SNOMED CT concept code for the allergy. E.g., '416098002' = Penicillin allergy." ;
    rdfs:label "snomedCode" .

rx:localCode
    a owl:DatatypeProperty ;
    rdfs:domain rx:Allergy ;
    rdfs:range  xsd:string ;
    rdfs:comment "Local terminology code for the allergy (e.g., laboratory-specific code). Aligned via terminology bridge in T." ;
    rdfs:label "localCode" .

rx:recordedAt
    a owl:DatatypeProperty ;
    rdfs:domain rx:Allergy ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Timestamp when the allergy was recorded." ;
    rdfs:label "recordedAt" .

# ── Medication data properties ────────────────────────────────────────────────

rx:medicationName
    a owl:DatatypeProperty ;
    rdfs:domain rx:Medication ;
    rdfs:range  xsd:string ;
    rdfs:comment "Human-readable name of the medication." ;
    rdfs:label "medicationName" .

rx:medicationId
    a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:domain rx:Medication ;
    rdfs:range  xsd:integer ;
    rdfs:comment "Numeric identifier for the medication (field element id(m) in ZKP circuit)." ;
    rdfs:label "medicationId" .

# ── Agent identity data properties ────────────────────────────────────────────

rx:did
    a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:comment "Decentralized Identifier (DID) of the agent. Used as patient/physician identifier in the prescription workflow." ;
    rdfs:label "did" .

rx:licenseNumber
    a owl:DatatypeProperty ;
    rdfs:domain rx:Physician ;
    rdfs:range  xsd:string ;
    rdfs:comment "Medical license number of the Physician. Verified via MFSSIA challenge C-DOC-1." ;
    rdfs:label "licenseNumber" .

# ── Data source data properties ───────────────────────────────────────────────

rx:sourceIdentifier
    a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:domain rx:TrustedDataSource ;
    rdfs:range  xsd:string ;
    rdfs:comment "Governance-approved identifier of the data source (src in Γ). Member of Strusted." ;
    rdfs:label "sourceIdentifier" .

rx:organizationType
    a owl:DatatypeProperty ;
    rdfs:domain rx:TrustedDataSource ;
    rdfs:range  xsd:string ;
    rdfs:comment "Type of organization: 'hospital', 'laboratory', 'pharmacy'. Used to validate source trustworthiness." ;
    rdfs:label "organizationType" .

# ── Evaluation context data properties ───────────────────────────────────────

rx:contextTimestamp
    a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:domain rx:EvaluationContext ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Timestamp ts of the evaluation context. Used in freshness check Valid(Γ)." ;
    rdfs:label "contextTimestamp" .

rx:tsAnchor
    a owl:DatatypeProperty ;
    rdfs:domain rx:EvaluationContext ;
    rdfs:range  xsd:integer ;
    rdfs:comment "Coarse-grained time anchor for on-chain auditability (public input in ZKP)." ;
    rdfs:label "tsAnchor" .

# ── Prescription workflow data properties ─────────────────────────────────────

rx:prescriptionStatus
    a owl:DatatypeProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  xsd:string ;
    rdfs:comment "Workflow status: 'PENDING', 'VALIDATED', 'DISPENSED', 'REJECTED'." ;
    rdfs:label "prescriptionStatus" .

rx:issuedAt
    a owl:DatatypeProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  xsd:dateTime ;
    rdfs:comment "Timestamp when the prescription was issued." ;
    rdfs:label "issuedAt" .

rx:dkgUal
    a owl:DatatypeProperty ;
    rdfs:domain rx:Prescription ;
    rdfs:range  xsd:string ;
    rdfs:comment "DKG Universal Asset Locator (UAL) where this prescription's governance record is anchored." ;
    rdfs:label "dkgUal" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 3 — CLASSES
# ═══════════════════════════════════════════════════════════════════════════════

# ── 3.1 Healthcare Agents ─────────────────────────────────────────────────────

rx:Physician
    a owl:Class ;
    rdfs:subClassOf mfssia:Agent ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty mfssia:isRegisteredBy ;
        owl:someValuesFrom rx:HealthcareProvider
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:holdsAttestation ;
        owl:someValuesFrom mfssia:Authentication
    ] ;
    ufo:role "UFO Role — a Physician is an Agent playing a context-dependent prescribing role within a HealthcareProvider." ;
    rdfs:comment """
        Represents a licensed medical physician who can initiate prescriptions.
        Corresponds to prescriber d ∈ D_D in Definition 2.
        Au(d, prescribe) is verified via their MFSSIA attestation (rx:PhysicianChallengeSet).
    """ ;
    rdfs:label "Physician" .

rx:Patient
    a owl:Class ;
    rdfs:subClassOf mfssia:Agent ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:hasConsent ;
        owl:someValuesFrom rx:DataSharingConsent
    ] ;
    ufo:kind "UFO Kind — Patient is a fundamental sortals providing identity criteria for persons in the healthcare domain." ;
    rdfs:comment """
        Represents a patient in the e-health prescription workflow.
        Corresponds to patient p ∈ D_P in Definition 2.
        Patient-specific clinical evidence (allergies, lab results) is stored off-chain
        and used only as private witness input during ZKP generation.
    """ ;
    rdfs:label "Patient" .

rx:HealthcareProvider
    a owl:Class ;
    rdfs:subClassOf mfssia:Organization ;
    ufo:kind "UFO Kind — HealthcareProvider is a collective organization providing medical services." ;
    rdfs:comment "Represents a healthcare organization (hospital) that employs physicians and manages EHR data." ;
    rdfs:label "HealthcareProvider" .

rx:Laboratory
    a owl:Class ;
    rdfs:subClassOf mfssia:Organization ;
    rdfs:subClassOf rx:TrustedDataSource ;
    ufo:kind "UFO Kind — Laboratory as a specialized organization providing diagnostic services." ;
    rdfs:comment """
        Represents a diagnostic laboratory producing clinical results (e.g., eGFR measurements).
        Must be a member of Strusted to be a valid src in EvaluationContext Γ.
        Authenticated via rx:LaboratoryChallengeSet.
    """ ;
    rdfs:label "Laboratory" .

rx:Pharmacy
    a owl:Class ;
    rdfs:subClassOf mfssia:Organization ;
    ufo:kind "UFO Kind — Pharmacy as an organization that dispenses medications." ;
    rdfs:comment """
        Represents a community pharmacy that dispenses prescribed medications.
        Authenticated via rx:PharmacyChallengeSet.
        Holds attestation for the action 'dispense'.
    """ ;
    rdfs:label "Pharmacy" .

# ── 3.2 Clinical Domain Entities ──────────────────────────────────────────────

rx:Medication
    a owl:Class ;
    rdfs:subClassOf mfssia:Asset ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:belongsToClass ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    ufo:kind "UFO Kind — Medication is a functional object with identity criteria provided by its pharmacological classification." ;
    rdfs:comment """
        Represents a specific medication (e.g., Metformin, Amoxicillin).
        Corresponds to m ∈ D_M in Definition 2.
        The medication identity id(m) is encoded as a field element in the ZKP circuit.
    """ ;
    rdfs:label "Medication" .

rx:MedicationClass
    a owl:Class ;
    rdfs:subClassOf mfssia:Data ;
    ufo:kind "UFO Kind — MedicationClass provides the sortal identity for grouping medications into pharmacological families." ;
    rdfs:comment """
        Represents a pharmacological class or drug family (e.g., β-lactam, antidiabetic).
        Corresponds to s ∈ D_S in Definition 2.
        The subsumption relation (⊑) over MedicationClass forms the ontological hierarchy in T.
        Example: Penicillin ⊑ β-lactam (Eq. 4).
    """ ;
    rdfs:label "MedicationClass" .

rx:Allergy
    a owl:Class ;
    rdfs:subClassOf mfssia:Data ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:allergicToSubstance ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger
    ] ;
    ufo:mode "UFO Mode — Allergy is an intrinsic quality of the Patient, existentially dependent on the Patient." ;
    rdfs:comment """
        Represents a documented allergy record for a patient.
        Corresponds to Al(p, s) in Definition 2 (Eq. 9): ⟨p, s⟩ ∈ I(Al).
        Stored off-chain; encoded in the ZKP witness as Merkle membership proof against root_Al.
        SNOMED CT / local terminology bridge: Sens(p,s) ↔ Al(p,s) (Eq. 6).
    """ ;
    rdfs:label "Allergy" .

rx:LabResult
    a owl:Class ;
    rdfs:subClassOf mfssia:Data ;
    ufo:mode "UFO Mode — LabResult is a quality (measurement) intrinsic to the Patient at a given time point." ;
    rdfs:comment """
        Represents a laboratory measurement result (e.g., eGFR = 45 ml/min).
        Provides ClinVal(p, t) for clinical policy checks PolOk(p, m) (Eq. 12).
        Private witness input in ZKP circuit; never disclosed on-chain.
        Freshness enforced by (tnow - ts) ≤ Δmax.
    """ ;
    rdfs:label "LabResult" .

rx:Prescription
    a owl:Class ;
    rdfs:subClassOf mfssia:Asset ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:prescribedBy ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass rx:Physician
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:prescribes ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass rx:Medication
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:prescribedFor ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass rx:Patient
    ] ;
    ufo:relator "UFO Relator — Prescription mediates the relationship between Physician, Patient, and Medication, externally dependent on all three." ;
    rdfs:comment """
        Represents a valid digital prescription Rx(d, p, m).
        Validity condition (Definition 2, Eq. 13):
            Au(d, prescribe) ∧ ¬Ct(p, m) ∧ PolOk(p, m)
        The stmtHash = H(φ+ ∥ policyVersion ∥ nonce) binds this instance to a ZKP proof.
    """ ;
    rdfs:label "Prescription" .

rx:ClinicalPolicy
    a owl:Class ;
    rdfs:subClassOf mfssia:SecurityPolicy ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:appliesToMedication ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass rx:Medication
    ] ;
    ufo:kind "UFO Kind — ClinicalPolicy is a NormativeDescription that constrains the dispensation of medications." ;
    rdfs:comment """
        Governance-approved clinical policy axiom Pol(m, t, op, θ).
        Published on the DKG as an OWL individual. The policyVersion (UAL) is embedded
        in stmtHash to ensure proof invalidation upon policy update.
        Example: Pol(Metformin, eGFR, ≥, 30) → rx:PolicyMetforminEGFR.
    """ ;
    rdfs:label "ClinicalPolicy" .

rx:EvaluationContext
    a owl:Class ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:hasDataSource ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass rx:TrustedDataSource
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty rx:usesCredential ;
        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass mfssia:Authentication
    ] ;
    ufo:relator "UFO Relator — EvaluationContext is an extrinsic relator mediating between the prescription event, the data source, and the credential." ;
    rdfs:comment """
        Represents the evaluation context Γ = ⟨src, ts, cred⟩ from Definition 1.
        Valid(Γ) ⟺ (tnow − ts) ≤ Δmax ∧ Auth(cred) ∧ src ∈ Strusted.
        Determines whether clinical evidence can be trusted before semantic evaluation.
    """ ;
    rdfs:label "EvaluationContext" .

rx:TrustedDataSource
    a owl:Class ;
    rdfs:subClassOf mfssia:Organization ;
    ufo:role "UFO Role — TrustedDataSource is a role played by an Organization that has been approved by governance as a reliable data provider." ;
    rdfs:comment """
        Represents a governance-approved data source (member of Strusted).
        Corresponds to src ∈ Strusted in Definition 1 (Valid(Γ)).
        Can be a hospital EHR, laboratory information system, or patient PHR.
        Authenticated via MFSSIA challenge sets before being admitted to Strusted.
    """ ;
    rdfs:label "TrustedDataSource" .

rx:PrescribingAuthority
    a owl:Class ;
    ufo:relator "UFO Relator — PrescribingAuthority mediates between a Physician and the institutional right to prescribe, externally dependent on both." ;
    rdfs:comment """
        Represents the authorization relation Au(d, prescribe).
        Links a Physician to their MFSSIA-attested prescribing right.
        A PrescribingAuthority instance exists iff the Physician has completed
        the rx:PhysicianChallengeSet and received a valid attestation.
    """ ;
    rdfs:label "PrescribingAuthority" .

rx:DataSharingConsent
    a owl:Class ;
    rdfs:subClassOf mfssia:Asset ;
    ufo:relator "UFO Relator — DataSharingConsent is a social commitment from the Patient to specific organizations, externally dependent on both." ;
    rdfs:comment """
        Represents the patient's consent to share clinical data across organizations
        (hospital, laboratory, pharmacy) in the prescription workflow.
        Required precondition for cross-organizational semantic evaluation.
        Attested via rx:PatientChallengeSet challenge C-PAT-2.
    """ ;
    rdfs:label "DataSharingConsent" .

# ── 3.3 Terminology Bridge Instances (Sens ↔ Al) ─────────────────────────────

# Local terminology sensitivity class — aligns to SNOMED allergy via bridge in T
rx:LocalSensitivity
    a owl:Class ;
    rdfs:subClassOf rx:Allergy ;
    skos:closeMatch snomed:416098002 ;
    rdfs:comment """
        Represents 'β-lactam sensitivity' as recorded in local laboratory terminology.
        Aligned to rx:Allergy via the terminology bridge axiom Sens(p,s) ↔ Al(p,s) (Eq. 6).
        This bridge is encoded in T and verified via Merkle membership proof in the ZKP circuit.
    """ ;
    rdfs:label "LocalSensitivity" .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 4 — MEDICATION CLASS HIERARCHY (ontological axioms in T)
# ═══════════════════════════════════════════════════════════════════════════════
# These instances represent the structure of D_S (substance domain).
# They are stored publicly on the DKG as part of theory T.
# The subsumption closure is used in ZKP circuit to prove m ⊑ s.

rx:BetaLactam
    a rx:MedicationClass, owl:NamedIndividual ;
    rx:medicationName "β-lactam" ;
    rdfs:comment "Pharmacological class: β-lactam antibiotics. E.g., Penicillin ⊑ β-lactam (Eq. 4)." ;
    rdfs:label "BetaLactam" ;
    skos:exactMatch snomed:372687004 .

rx:Penicillin
    a rx:MedicationClass, owl:NamedIndividual ;
    rx:medicationName "Penicillin" ;
    rx:subsumes rx:BetaLactam ;
    rdfs:comment "Penicillin ⊑ β-lactam. Used in inference rule: Al(p, Penicillin) → Ct(p, β-lactam)." ;
    rdfs:label "Penicillin" ;
    skos:exactMatch snomed:764146007 .

rx:Amoxicillin
    a rx:MedicationClass, owl:NamedIndividual ;
    rx:medicationName "Amoxicillin" ;
    rx:subsumes rx:Penicillin ;
    rdfs:comment "Amoxicillin ⊑ Penicillin ⊑ β-lactam. Contraindicated if Al(p, Penicillin)." ;
    rdfs:label "Amoxicillin" .

rx:Antidiabetic
    a rx:MedicationClass, owl:NamedIndividual ;
    rx:medicationName "Antidiabetic" ;
    rdfs:comment "Pharmacological class: antidiabetic agents. Metformin ⊑ Antidiabetic." ;
    rdfs:label "Antidiabetic" ;
    skos:exactMatch snomed:372689001 .


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 5 — DISJOINTNESS AXIOMS
# ═══════════════════════════════════════════════════════════════════════════════

[] a owl:AllDisjointClasses ;
    owl:members (
        rx:Physician
        rx:Patient
        rx:Laboratory
        rx:Pharmacy
    ) .

[] a owl:AllDisjointClasses ;
    owl:members (
        rx:Medication
        rx:Allergy
        rx:LabResult
        rx:ClinicalPolicy
        rx:Prescription
    ) .
