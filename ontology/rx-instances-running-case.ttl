@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

@prefix mfssia: <http://www.semanticweb.org/mubashar/ontologies/2024/4/MFSSIA-ontology#> .
@prefix rx:     <https://mfssia.io/ontology/prescription#> .

# ═══════════════════════════════════════════════════════════════════════════════
# RUNNING CASE INSTANCE DATA
# Implements the Metformin prescription scenario from Section III-A and VI-E
# of: "Resolving Semantic Conflicts in Decentralized E-Health Governance
#      Using Zero-Knowledge Proofs" (Kormiltsyn, Udokwu, Norta, 2025)
#
# Statement: φ+ = Rx(doc1, pat1, Metformin)
# Evaluation: M, Γ |= Rx(doc1, pat1, Metformin) → outcome = 1
# ═══════════════════════════════════════════════════════════════════════════════

# ── 1. ORGANIZATIONS (TrustedDataSources / Strusted) ──────────────────────────

rx:CityHospital
    a rx:HealthcareProvider, rx:TrustedDataSource, owl:NamedIndividual ;
    rx:sourceIdentifier "hospital-1" ;
    rx:organizationType "hospital" ;
    rdfs:comment "Public hospital — trusted data source (src ∈ Strusted). Manages EHR for pat1." ;
    rdfs:label "City Hospital" ;
    prov:generatedAtTime "2026-04-08T00:00:00"^^xsd:dateTime .

rx:DiagLab1
    a rx:Laboratory, rx:TrustedDataSource, owl:NamedIndividual ;
    rx:sourceIdentifier "lab-1" ;
    rx:organizationType "laboratory" ;
    rdfs:comment "Private diagnostics laboratory — trusted data source (src ∈ Strusted). Measured eGFR for pat1." ;
    rdfs:label "DiagLab-1" ;
    prov:generatedAtTime "2026-04-08T00:00:00"^^xsd:dateTime .

rx:CommunityPharmacy1
    a rx:Pharmacy, owl:NamedIndividual ;
    rdfs:comment "Community pharmacy — dispenses medications after prescription validation." ;
    rdfs:label "Community Pharmacy 1" ;
    prov:generatedAtTime "2026-04-08T00:00:00"^^xsd:dateTime .

# ── 2. MEDICATIONS ────────────────────────────────────────────────────────────

rx:Metformin
    a rx:Medication, owl:NamedIndividual ;
    rx:medicationName "Metformin" ;
    rx:medicationId 5 ;
    rx:belongsToClass rx:Antidiabetic ;
    rdfs:comment "Metformin 500mg — antidiabetic medication. Subject to policy: Pol(Metformin, eGFR, ≥, 30)." ;
    rdfs:label "Metformin" ;
    skos:exactMatch <http://snomed.info/id/372725003> .

rx:AmoxicillinMed
    a rx:Medication, owl:NamedIndividual ;
    rx:medicationName "Amoxicillin 500mg" ;
    rx:medicationId 2 ;
    rx:belongsToClass rx:Amoxicillin ;
    rdfs:comment "Amoxicillin — β-lactam antibiotic. Contraindicated if Al(pat1, Penicillin) (via subsumption)." ;
    rdfs:label "Amoxicillin 500mg" .

# ── 3. STAKEHOLDER AGENTS ──────────────────────────────────────────────────────

rx:doc1
    a rx:Physician, owl:NamedIndividual ;
    rx:did "did:mfssia:physician:doc1" ;
    rx:licenseNumber "MED-LIC-2024-001" ;
    mfssia:isRegisteredBy rx:CityHospital ;
    rdfs:comment """
        Physician doc1 — prescribes Metformin for pat1.
        d ∈ D_D in Rx(doc1, pat1, Metformin).
        Holds attestation from rx:PhysicianChallengeSet → Au(doc1, prescribe).
        Encoded in ZKP: doctorId=123, doctorSecret=456.
    """ ;
    rdfs:label "Doctor 1" ;
    prov:generatedAtTime "2026-04-08T00:00:00"^^xsd:dateTime .

rx:pat1
    a rx:Patient, owl:NamedIndividual ;
    rx:did "did:mfssia:patient:pat1" ;
    rdfs:comment """
        Patient pat1 — recipient of Metformin prescription.
        p ∈ D_P in Rx(doc1, pat1, Metformin).
        Has documented Penicillin allergy (Al(pat1, Penicillin)).
        eGFR = 45 ml/min (PolOk(pat1, Metformin) satisfied: 45 ≥ 30).
        Clinical data stays off-chain as private ZKP witness.
    """ ;
    rdfs:label "Patient 1" ;
    prov:generatedAtTime "2026-04-08T00:00:00"^^xsd:dateTime .

# ── 4. CLINICAL DATA (off-chain private evidence — stored for witness generation) ──

rx:AllergyPat1Penicillin
    a rx:Allergy, owl:NamedIndividual ;
    rx:allergicToSubstance rx:Penicillin ;
    rx:snomedCode "416098002" ;
    rx:localCode "beta-lac-sens" ;
    rx:recordedAt "2025-06-15T10:30:00"^^xsd:dateTime ;
    rdfs:comment """
        Al(pat1, Penicillin) — documented Penicillin allergy for pat1.
        SNOMED CT: 416098002 (allergy to penicillin).
        Local lab code: 'beta-lac-sens' (β-lactam sensitivity) — aligned via
        terminology bridge Sens(p,s) ↔ Al(p,s) in theory T.
        Does NOT contraindicate Metformin (Amoxicillin ⊑ Penicillin, not Metformin).
        Encoded in ZKP: allergyClassId=2 (β-lactam), medicationClassId=5 (antidiabetic).
        allergyClassId ≠ medicationClassId → noContra = 1 → S1 valid baseline.
    """ ;
    rdfs:label "Penicillin Allergy (pat1)" .

rx:LabEGFRpat1
    a rx:LabResult, owl:NamedIndividual ;
    rx:conditionType "eGFR" ;
    rx:clinicalValue "45"^^xsd:decimal ;
    rx:measuredAt "2026-03-10T08:00:00"^^xsd:dateTime ;
    rx:measuredBy rx:DiagLab1 ;
    rdfs:comment """
        ClinVal(pat1, eGFR) = 45 ml/min/1.73m².
        Satisfies Pol(Metformin, eGFR, ≥, 30): 45 ≥ 30 → polOk = 1.
        LOINC: 33914-3 (Glomerular filtration rate/1.73 sq M predicted).
        Private ZKP witness: clinVal=45, θ=30.
        Freshness: measuredAt 29 days ago; dataAge=30 ≤ Δmax=90 → freshOk = 1.
    """ ;
    rdfs:label "eGFR Lab Result (pat1)" ;
    skos:exactMatch <http://loinc.org/rdf#33914-3> .

# ── 5. AUTHORIZATION (Au(doc1, prescribe)) ────────────────────────────────────

rx:PhysicianAuth_doc1
    a rx:PrescribingAuthority, owl:NamedIndividual ;
    rx:grantsAuthorityTo rx:doc1 ;
    rdfs:comment """
        PrescribingAuthority relator for doc1.
        Mediates between doc1 and the institutional right to prescribe.
        Exists because doc1 completed rx:PhysicianChallengeSet and received attestation.
        Au(doc1, prescribe) = true → auth_ok = 1 in ZKP circuit.
    """ ;
    rdfs:label "Prescribing Authority for doc1" .

# ── 6. DATA SHARING CONSENT ───────────────────────────────────────────────────

rx:ConsentPat1
    a rx:DataSharingConsent, owl:NamedIndividual ;
    rx:consentCovers rx:CityHospital ;
    rx:consentCovers rx:DiagLab1 ;
    rx:consentCovers rx:CommunityPharmacy1 ;
    rdfs:comment """
        Patient pat1's consent to share clinical data across the three
        organizations in the prescription workflow.
        Required precondition for cross-organizational semantic evaluation.
        Verified via MFSSIA challenge C-PAT-2.
    """ ;
    rdfs:label "Data Sharing Consent (pat1)" .

# ── 7. EVALUATION CONTEXT Γ = ⟨src, ts, cred⟩ ───────────────────────────────

rx:EvalCtx_Prescription1
    a rx:EvaluationContext, owl:NamedIndividual ;
    rx:hasDataSource rx:DiagLab1 ;
    rx:contextTimestamp "2026-04-08T10:00:00"^^xsd:dateTime ;
    rx:tsAnchor 90 ;
    rdfs:comment """
        Evaluation context Γ = ⟨lab-1, 2026-04-08T10:00:00, cred_doc1⟩.
        Valid(Γ) check:
          - src = lab-1 ∈ Strusted ✓
          - (tnow - ts) = 29 days = ~2505600s ≤ Δmax=7776000s (90 days) ✓
          - Auth(cred_doc1): doc1 holds valid PhysicianChallengeSet attestation ✓
        All three conjuncts satisfied → Valid(Γ) = true.
    """ ;
    rdfs:label "Evaluation Context for Prescription 1" .

# ── 8. PRESCRIPTION INSTANCE (φ+ = Rx(doc1, pat1, Metformin)) ────────────────

rx:Prescription1
    a rx:Prescription, owl:NamedIndividual ;

    # Core Rx(d, p, m) components
    rx:prescribedBy rx:doc1 ;
    rx:prescribedFor rx:pat1 ;
    rx:prescribes rx:Metformin ;

    # Evaluation context binding
    rx:evaluatedUnder rx:EvalCtx_Prescription1 ;

    # Governance policy
    rx:governedBy rx:PolicyMetforminEGFR ;

    # ZKP binding (Eq. 14 from paper)
    rx:stmtHash "20269...8730" ;
    rx:nonce "42" ;
    rx:policyVersion "ual:dkg:prescription-policy:v1" ;
    rx:proofOutcome true ;

    # Workflow state
    rx:prescriptionStatus "VALIDATED" ;
    rx:issuedAt "2026-04-08T10:05:00"^^xsd:dateTime ;

    rdfs:comment """
        Valid prescription: Rx(doc1, pat1, Metformin).
        Semantic validity (Definition 2, Eq. 13):
          Au(doc1, prescribe)  → auth_ok = 1  ✓
          ¬Ct(pat1, Metformin) → no_contra = 1 ✓  (allergy=β-lactam ≠ antidiabetic)
          PolOk(pat1, Metformin) → pol_ok = 1 ✓   (eGFR=45 ≥ θ=30)
          outcome = valid_ctx ∧ clinical_ok = 1 ✓
        ZKP: Verify_vk(π, pub) = true (S1 — Valid Baseline scenario).
    """ ;
    rdfs:label "Prescription 1 — Metformin for pat1" ;
    prov:generatedAtTime "2026-04-08T10:05:00"^^xsd:dateTime ;
    prov:wasAttributedTo rx:doc1 .

# ── 9. REJECTED SCENARIO (S5a — Honest Reject: Amoxicillin contraindicated) ──

rx:Prescription2_Rejected
    a rx:Prescription, owl:NamedIndividual ;
    rx:prescribedBy rx:doc1 ;
    rx:prescribedFor rx:pat1 ;
    rx:prescribes rx:AmoxicillinMed ;
    rx:evaluatedUnder rx:EvalCtx_Prescription1 ;
    rx:proofOutcome false ;
    rx:prescriptionStatus "REJECTED" ;
    rx:issuedAt "2026-04-08T10:10:00"^^xsd:dateTime ;
    rdfs:comment """
        Rejected prescription: Rx(doc1, pat1, Amoxicillin).
        Contraindication detected:
          Al(pat1, Penicillin) ∧ (Amoxicillin ⊑ Penicillin) → Ct(pat1, Amoxicillin)
          allergy_contra = 1 → no_contra = 0 → clinical_ok = 0 → outcome = 0.
        ZKP S5a scenario: honest reject proof generated with outcome=0.
        Auditable on-chain without revealing allergy class.
    """ ;
    rdfs:label "Prescription 2 — Amoxicillin REJECTED (contraindication)" .

# ── 10. SEMANTIC CONFLICT EXAMPLE ─────────────────────────────────────────────

rx:TerminologyConflict_PenicillinSensitivity
    a owl:NamedIndividual ;
    rdfs:comment """
        Semantic conflict (Fig. 2 from paper):
          Hospital EHR: Al(pat1, Penicillin) via SNOMED CT code '416098002'
          Laboratory system: Sens(pat1, β-lactam) via local code 'beta-lac-sens'
          → Terminological conflict: two predicates, one clinical fact.

        Resolution via theory T bridge axiom (Eq. 6):
          ∀p ∈ D_P ∀s ∈ D_S: Sens(p, s) ↔ Al(p, s)
          → Both records are semantically equivalent.

        In ZKP circuit: either root_Al or root_Sens membership proof
          satisfies the same allergy gate (predicate alias constraint).
    """ ;
    rdfs:label "Terminology Conflict: Penicillin Allergy vs β-lactam Sensitivity" .
